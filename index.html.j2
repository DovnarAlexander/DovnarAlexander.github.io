<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>Alex Dovnar - DevOps & Cloud Architect</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Alex Dovnar - DevOps and Cloud Architect with 10+ years of experience in AWS, Kubernetes, Terraform, and CI/CD" />
  <meta name="keywords" content="devops, cloud, aws, kubernetes, terraform, architect, engineer" />
    <link rel="shortcut icon" href="favicon.ico">

  <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap">

  <!-- Styles -->
    <link rel="stylesheet" href="css/tailwind.css" type="text/css">
    <link rel="stylesheet" href="css/magnific-popup.css" type="text/css">
  <link rel="stylesheet" href="fonts/fontawesome-free/css/all.min.css" type="text/css">
  </head>

  <body class="min-h-dvh bg-bg font-sans text-fg">

  <!-- Context Bar -->
  <header class="ctx-bar">
    <button class="ctx-burger" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="sidebar">
      <i class="fas fa-bars"></i>
    </button>
    <a href="#home" class="hidden font-mono text-base font-semibold text-k8s sm:inline">&gt; alex-dovnar</a>
    <span class="ctx-pill"><span class="status-dot status-ok"></span>ctx:&nbsp;<b>prod</b></span>
    <span class="ctx-pill hidden sm:flex">ns:&nbsp;<b>default</b></span>
    <span class="ctx-pill hidden md:flex">ready&nbsp;▸</span>
    <nav class="ml-auto flex gap-2">
      <a href="uploads/DevOps-Alexander-Dovnar-EN.pdf" target="_blank" rel="noopener" class="cv-btn">CV EN</a>
      <a href="uploads/DevOps-Alexander-Dovnar-RU.pdf" target="_blank" rel="noopener" class="cv-btn">CV RU</a>
    </nav>
  </header>

  <!-- Dashboard Grid -->
  <div class="grid grid-cols-1 pt-12 lg:grid-cols-[240px_minmax(0,1fr)] xl:grid-cols-[240px_minmax(0,1fr)_300px]">

    <!-- Sidebar (resource nav) -->
    <aside id="sidebar"
      class="fixed bottom-0 left-0 top-12 z-40 w-60 -translate-x-full overflow-y-auto border-r border-border bg-panel transition-transform duration-200 lg:sticky lg:top-12 lg:h-[calc(100dvh-3rem)] lg:w-auto lg:translate-x-0">
      <p class="nav-label">Resources</p>
      <nav class="flex flex-col pb-4">
        <a href="#home" class="nav-item"><i class="fas fa-terminal"></i>home</a>
        <a href="#about" class="nav-item"><i class="fas fa-id-card"></i>about</a>
        <a href="#experience" class="nav-item"><i class="fas fa-briefcase"></i>experience<span class="nav-count">4</span></a>
        <a href="#skills" class="nav-item"><i class="fas fa-layer-group"></i>skills</a>
        <a href="#education" class="nav-item"><i class="fas fa-graduation-cap"></i>education</a>
        <a href="#blog" class="nav-item"><i class="fas fa-rss"></i>blog<span class="nav-count">{{ posts|length if posts else 0 }}</span></a>
        <a href="#videos" class="nav-item"><i class="fas fa-video"></i>talks<span class="nav-count">70+</span></a>
        <a href="#contact" class="nav-item"><i class="fas fa-envelope"></i>contact</a>
      </nav>
    </aside>
    <div id="nav-backdrop" class="fixed inset-0 top-12 z-30 hidden bg-black/50 lg:hidden"></div>

    <!-- Main column -->
    <main class="mx-auto flex w-full min-w-0 max-w-[1100px] flex-col gap-6 px-4 py-6 sm:px-6">

      <!-- Highlights — mobile/tablet chip strip -->
      <div class="highlights-strip sticky top-12 z-30 bg-bg/90 backdrop-blur xl:hidden"
           tabindex="0" role="region" aria-label="Certifications and communities">
        <div class="chip-flow">{{ highlights_html | safe }}</div>
      </div>

      <!-- Hero -->
      <section id="home" class="panel fade-in scroll-mt-16">
        <div class="hero-panel">
          <div class="hero-prompt">&gt; whoami</div>
          <h1 class="hero-title">Alex Dovnar<span class="hero-cursor"></span></h1>
          <p class="hero-subtitle">DevOps &amp; Cloud Architect</p>
          <div class="hero-actions">
            <a href="uploads/DevOps-Alexander-Dovnar-EN.pdf" class="hero-btn hero-btn-primary" target="_blank" rel="noopener">Download CV (EN)</a>
            <a href="uploads/DevOps-Alexander-Dovnar-RU.pdf" class="hero-btn" target="_blank" rel="noopener">Скачать Резюме (RU)</a>
          </div>
          <div class="hero-social">
            <a href="https://www.linkedin.com/in/dovnaralex/" target="_blank" rel="noopener" title="LinkedIn">
              <i class="fab fa-linkedin-in"></i>
            </a>
          </div>
        </div>
      </section>

      <!-- About -->
      <section id="about" class="panel fade-in scroll-mt-16">
        <div class="panel-head">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">kubectl describe</span><span class="prompt-res">profile</span>
        </div>
        <div class="panel-body">
          {{ about_me_html | safe }}
        </div>
      </section>

      <!-- Experience -->
      <section id="experience" class="panel fade-in scroll-mt-16">
        <div class="panel-head">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">kubectl get</span><span class="prompt-res">experience</span>
          <span class="panel-meta">READY <b>4/4</b> · AGE <b>14y</b></span>
        </div>
        <div class="panel-body">
          {{ experience_html | safe }}
        </div>
      </section>

      <!-- Skills -->
      <section id="skills" class="panel fade-in scroll-mt-16">
        <div class="panel-head">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">kubectl get</span><span class="prompt-res">skills</span><span class="prompt-flag">-o wide</span>
        </div>
        <div class="panel-body">
          {{ skills_html | safe }}
        </div>
      </section>

      <!-- Education -->
      <section id="education" class="panel fade-in scroll-mt-16">
        <div class="panel-head">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">kubectl get</span><span class="prompt-res">education</span>
        </div>
        <div class="panel-body">
          {{ education_html | safe }}
        </div>
      </section>

      <!-- Blog -->
      <section id="blog" class="panel fade-in scroll-mt-16">
        <div class="panel-head">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">kubectl get</span><span class="prompt-res">posts</span><span class="prompt-flag">-A</span>
        </div>
        <div class="panel-body">
          {% if posts %}
          <ul class="post-list">
            {% for post in posts %}
            <li class="post-item">
              <a href="{{ post.url }}" class="post-link">
                <span class="post-title">{{ post.title }}</span>
                {% if post.date_human %}<span class="post-date">{{ post.date_human }}</span>{% endif %}
              </a>
              {% if post.excerpt %}<p class="post-excerpt">{{ post.excerpt }}</p>{% endif %}
              {% if post.tags %}<p class="post-tags">{% for tag in post.tags %}<span class="post-tag">#{{ tag }}</span> {% endfor %}</p>{% endif %}
            </li>
            {% endfor %}
          </ul>
          {% else %}
          <p class="empty-state">No resources found in default namespace.</p>
          <p class="mt-2 text-sm text-dim">Articles on DevOps, Cloud Architecture &amp; best practices — coming soon.</p>
          {% endif %}
        </div>
      </section>

      <!-- Videos -->
      <section id="videos" class="panel fade-in scroll-mt-16">
        <div class="panel-head">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">kubectl get</span><span class="prompt-res">talks</span><span class="prompt-flag">-A</span>
        </div>
        <div class="panel-body">

          <!-- Video Filters -->
          <ul class="portfolio-filters">
            <li class="active">
              <a class="filter" data-group="all">All</a>
            </li>
            <li>
              <a class="filter" data-group="youtube-videos">YouTube Videos</a>
            </li>
            <li>
              <a class="filter" data-group="devops-kitchen">DevOps Kitchen Talks</a>
            </li>
            <li>
              <a class="filter" data-group="public-talks">Public talks</a>
            </li>
          </ul>

          <!-- Video Grid -->
          <div class="portfolio-grid" id="video-grid">
            {% set has_groups = has_groups if has_groups is defined else (youtube_groups is defined and youtube_groups) %}
            {% if has_groups %}
              {% for group_name, group_items in youtube_groups.items() if group_items %}
                {% for id, info in group_items %}
                  {% set group_tag = 'devops-kitchen' if 'DevOps' in group_name else 'public-talks' %}
                  <figure class="item" data-groups='["all","youtube-videos","{{ group_tag }}"]'>
                    <div class="portfolio-item-img">
                      <img src="https://i1.ytimg.com/vi/{{ id }}/mqdefault.jpg" alt="{{ info["title"] }}" title="{{ info["title"] }}" />
                      <a href="https://www.youtube.com/embed/{{ id }}" class="lightbox mfp-iframe" title="{{ info["title"] }}"></a>
                    </div>
                    <i class="fas fa-video"></i>
                    <h4 class="name">{{ info["title"] }}</h4>
                    <span class="category">{{ group_name }}</span>
                  </figure>
                {% endfor %}
              {% endfor %}
            {% else %}
              {% for id, info in youtube_links %}
                <figure class="item" data-groups='["all","youtube-videos"]'>
                  <div class="portfolio-item-img">
                    <img src="https://i1.ytimg.com/vi/{{ id }}/mqdefault.jpg" alt="{{ info["title"] }}" title="{{ info["title"] }}" />
                    <a href="https://www.youtube.com/embed/{{ id }}" class="lightbox mfp-iframe" title="{{ info["title"] }}"></a>
                  </div>
                  <i class="fas fa-video"></i>
                  <h4 class="name">{{ info["title"] }}</h4>
                  <span class="category">YouTube Videos</span>
                </figure>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="panel fade-in scroll-mt-16">
        <div class="panel-head" style="border-bottom-color: var(--color-ok);">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">whois</span><span class="prompt-res">alex-dovnar.in</span>
        </div>
        <div class="panel-body">
          <div class="contact-info">
            <div class="contact-item"><strong>Email:</strong> <a href="mailto:alex@alex-dovnar.in">alex@alex-dovnar.in</a></div>
            <div class="contact-item"><strong>LinkedIn:</strong> <a href="https://www.linkedin.com/in/dovnaralex/" target="_blank" rel="noopener">/in/dovnaralex</a></div>
            <div class="contact-item"><strong>Location:</strong> Minsk, Belarus</div>
            <div class="contact-item mt-4 text-dim">© 2025 Alex Dovnar. All rights reserved.</div>
          </div>
        </div>
      </section>

    </main>

    <!-- Highlights — desktop sticky panel -->
    <aside class="hidden xl:block">
      <div class="panel sticky top-16 mr-4 mt-6 max-h-[calc(100dvh-5rem)] overflow-y-auto">
        <div class="panel-head">
          <span class="prompt-cursor">$</span><span class="prompt-cmd">kubectl get</span><span class="prompt-res">certifications</span>
        </div>
        <div class="panel-body highlights-panel">
          {{ highlights_html | safe }}
        </div>
      </div>
    </aside>

  </div><!-- /.grid -->

  <!-- Scripts -->
    <script src="js/jquery.min.js"></script>
    <script src="js/jquery.magnific-popup.min.js"></script>

  <script>
    $(document).ready(function () {
      // Open highlight links in a new tab
      $('.chip-flow a, .highlights-panel a').attr('target', '_blank').attr('rel', 'noopener noreferrer');

      // ── Mobile nav drawer ──────────────────────────────────────────
      var sidebar = document.getElementById('sidebar');
      var backdrop = document.getElementById('nav-backdrop');
      var toggle = document.getElementById('nav-toggle');

      function navIsOpen() { return toggle.getAttribute('aria-expanded') === 'true'; }
      function openNav() {
        sidebar.classList.remove('-translate-x-full');
        backdrop.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      }
      function closeNav() {
        sidebar.classList.add('-translate-x-full');
        backdrop.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }

      if (toggle) {
        toggle.addEventListener('click', function () {
          navIsOpen() ? closeNav() : openNav();
        });
      }
      if (backdrop) backdrop.addEventListener('click', closeNav);
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeNav();
      });

      // ── Scroll-spy: highlight the active sidebar item ───────────────
      var navItems = Array.prototype.slice.call(document.querySelectorAll('.nav-item'));
      function navItemFor(id) {
        return navItems.filter(function (a) { return a.getAttribute('href') === '#' + id; })[0];
      }
      var spy = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            navItems.forEach(function (a) { a.classList.remove('active'); });
            var item = navItemFor(entry.target.id);
            if (item) item.classList.add('active');
          }
        });
      }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
      document.querySelectorAll('main section[id]').forEach(function (s) { spy.observe(s); });

      // ── Smooth scroll for anchor links (closes the drawer) ──────────
      $('a[href^="#"]').on('click', function (e) {
        var target = $(this.getAttribute('href'));
        if (target.length) {
          e.preventDefault();
          if (navIsOpen()) closeNav();
          $('html, body').stop().animate({ scrollTop: target.offset().top - 64 }, 500);
        }
      });

      // ── Video grid filtering ────────────────────────────────────────
      var $items = $('#video-grid').find('.item');
      $items.css({ display: 'block', opacity: '1' });

      $('.portfolio-filters a').on('click', function (e) {
        e.preventDefault();
        var $this = $(this);
        var filterValue = $this.attr('data-group');
        $('.portfolio-filters li').removeClass('active');
        $this.parent().addClass('active');

        if (filterValue === 'all') {
          $items.fadeIn(300);
        } else {
          $items.each(function () {
            var groups = $(this).attr('data-groups');
            if (groups && groups.indexOf(filterValue) !== -1) {
              $(this).fadeIn(300);
            } else {
              $(this).fadeOut(300);
            }
          });
        }
      });

      // ── Lightbox for videos ─────────────────────────────────────────
      $('.lightbox').magnificPopup({
        type: 'iframe',
        mainClass: 'mfp-fade',
        removalDelay: 160,
        preloader: false,
        fixedContentPos: false,
        iframe: {
          markup: '<div class="mfp-iframe-scaler">' +
                    '<div class="mfp-close"></div>' +
                    '<iframe class="mfp-iframe" frameborder="0" allowfullscreen></iframe>' +
                  '</div>',
          patterns: {
            youtube: {
              index: 'youtube.com/',
              id: function (url) {
                var m = url.match(/embed\/([^?]+)/);
                if (!m || !m[1]) return null;
                return m[1];
              },
              src: 'https://www.youtube.com/embed/%id%?autoplay=1'
            }
          },
          srcAction: 'iframe_src'
        }
      });

      // ── Fade-in on scroll ───────────────────────────────────────────
      var fadeObserver = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      document.querySelectorAll('.fade-in').forEach(function (el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.5s ease-out, transform 0.5s ease-out';
        fadeObserver.observe(el);
      });
    });
  </script>
  </body>
</html>
